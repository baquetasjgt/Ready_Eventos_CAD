# Copia este fichero a .env y rellena los valores.

# --- Supabase (base de datos + auth + storage) ---
# La URL y la clave "publishable" son públicas por diseño (van en el navegador);
# la seguridad la da el Row Level Security. Se pueden poner tal cual.
VITE_SUPABASE_URL=https://jvjhqdwlhaggoqsnenfw.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_f0DmKuM5XGy5YXikIgoLNw_bNjJjPPb

# --- IA (Gemini) ---
# Déjala vacía: en producción la IA pasa por la Edge Function "ai" de Supabase
# (supabase/functions/ai), que guarda la clave en el servidor y sólo atiende a
# miembros. Rellénala únicamente para desarrollo local sin Supabase — nunca la
# subas al repositorio (.env está en .gitignore).
VITE_GEMINI_API_KEY=
